page {
  min-height: 100vh;
  background: #f7f1e6;
  color: #24180f;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
input,
button {
  box-sizing: border-box;
}

.page {
  min-height: 100vh;
  padding: 28rpx;
}

.section {
  margin-bottom: 24rpx;
}

.panel {
  padding: 24rpx;
  border: 1rpx solid rgba(54, 35, 20, 0.18);
  border-radius: 8rpx;
  background: rgba(255, 252, 245, 0.92);
  box-shadow: 0 10rpx 28rpx rgba(43, 28, 14, 0.08);
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.25;
}

.kicker {
  display: block;
  margin-bottom: 8rpx;
  color: #8b5a25;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.muted {
  color: #766454;
  font-size: 24rpx;
  line-height: 1.55;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.button-row button {
  flex: 1;
}

.btn {
  min-height: 76rpx;
  padding: 0 24rpx;
  border: 1rpx solid transparent;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 76rpx;
}

.btn-primary {
  color: #fff;
  background: #7a3b16;
}

.btn-ghost {
  color: #3a2718;
  border-color: rgba(72, 45, 25, 0.28);
  background: #fffaf0;
}

.btn-danger {
  color: #fff;
  background: #8f2d24;
}

.input {
  width: 100%;
  height: 86rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(54, 35, 20, 0.24);
  border-radius: 8rpx;
  background: #fffdf7;
  color: #24180f;
  font-size: 28rpx;
}

.pill {
  display: inline-flex;
  align-items: center;
  min-height: 46rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(91, 60, 31, 0.18);
  border-radius: 999rpx;
  background: #fff8eb;
  color: #5c4028;
  font-size: 22rpx;
  font-weight: 700;
}

.empty {
  padding: 32rpx 20rpx;
  border: 1rpx dashed rgba(72, 45, 25, 0.24);
  border-radius: 8rpx;
  color: #756350;
  font-size: 26rpx;
  line-height: 1.6;
  text-align: center;
}
